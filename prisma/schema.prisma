generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════
// CORE
// ═══════════════════════════════════════════════════════════════

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  state        String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branding           BrandingConfig?
  settings           TenantSetting[]
  members            TenantMember[]
  communities        Community[]
  events             Event[]
  studyCategories    StudyCategory[]
  studyMaterials     StudyMaterial[]
  liveStreams        LiveStream[]
  notifications      Notification[]
  pages              Page[]
  banners            Banner[]
  integrations       IntegrationConfig[]
  auditLogs          AuditLog[]
  tzedakaCampaigns   TzedakaCampaign[]
  tzedakaDonations   TzedakaDonation[]
  tzedakaAllocations TzedakaAllocation[]
  tzedakaReports     TzedakaReport[]
  libraryAuthors     LibraryAuthor[]
  libraryCategories  LibraryCategory[]
  libraryItems       LibraryItem[]
  libraryTags        LibraryTag[]
  forumCategories    ForumCategory[]
  forumTopics        ForumTopic[]
  forumPosts         ForumPost[]
  rabbiProfiles      RabbiProfile[]
  rabbiQuestions     RabbiQuestion[]
  aiConversations    AIConversation[]
  galleryAlbums      GalleryAlbum[]
  galleryMedia       GalleryMedia[]
  newsCategories     NewsCategory[]
  newsArticles       NewsArticle[]
  newsTags           NewsTag[]
  certificateTemplates CertificateTemplate[]
  certificates       Certificate[]
  partnerInstitutions PartnerInstitution[]
  speakers           Speaker[]
  prayerRequests     PrayerRequest[]
  volunteerOpps      VolunteerOpportunity[]
  mentorProfiles     MentorProfile[]
  mentorships        Mentorship[]
  searchHistories    SearchHistory[]
  aiConfig           AIConfig?
  aiUsageLogs        AIUsageLog[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  bio           String?   @db.Text
  passwordHash  String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  tenantMembers      TenantMember[]
  communityMembers   CommunityMember[]
  createdEvents      Event[]            @relation("EventCreator")
  uploadedStudies    StudyMaterial[]     @relation("StudyUploader")
  eventRegistrations EventRegistration[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  tzedakaDonations   TzedakaDonation[]
  rabbiQuestions     RabbiQuestion[]
  aiConversations    AIConversation[]
  galleryMedia       GalleryMedia[]
  newsArticles       NewsArticle[]      @relation("NewsAuthor")
  newsComments       NewsComment[]
  certificates       Certificate[]
  speakerProfile     Speaker?
  prayerRequests     PrayerRequest[]
  prayerResponses    PrayerResponse[]
  volunteerSignups   VolunteerSignup[]
  mentorProfiles     MentorProfile[]
  mentorshipsAsMentee Mentorship[]      @relation("Mentee")
  mentorshipsAsMentor Mentorship[]      @relation("Mentor")
  forumTopics        ForumTopic[]
  forumPosts         ForumPost[]
  forumReactions     ForumReaction[]
  favorites          UserFavorite[]
  searchHistories    SearchHistory[]
  preferences        UserPreference?
  aiUsageLogs        AIUsageLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TenantMember {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════
// BRANDING & SETTINGS
// ═══════════════════════════════════════════════════════════════

model BrandingConfig {
  id              String @id @default(cuid())
  tenantId        String @unique
  platformName    String @default("Portal Bnei Noach")
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String @default("#1a56db")
  secondaryColor  String @default("#1e40af")
  backgroundColor String @default("#ffffff")
  textColor       String @default("#111827")
  accentColor     String @default("#f59e0b")
  slogan          String?
  footerText      String?
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantSetting {
  id       String @id @default(cuid())
  tenantId String
  group    String  // "features", "integrations", "seo", "general"
  key      String
  valueStr String?
  valueBool Boolean?
  valueInt Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, group, key])
  @@index([tenantId])
  @@index([group])
}

model UserPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  theme           String  @default("system")  // "light", "dark", "system"
  language        String  @default("pt-BR")
  notifyEmail     Boolean @default(true)
  notifyInApp     Boolean @default(true)
  notifyEvents    Boolean @default(true)
  notifyStudies   Boolean @default(true)
  notifyNews      Boolean @default(true)
  fontSize        String  @default("normal")  // "small", "normal", "large"
  reducedMotion   Boolean @default(false)
  highContrast    Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// COMUNIDADES
// ═══════════════════════════════════════════════════════════════

model Community {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  slug            String
  description     String?  @db.Text
  address         String?
  city            String
  state           String
  phone           String?
  email           String?
  whatsappLink    String?
  meetingSchedule String?  @db.Text
  latitude        Float?
  longitude       Float?
  logoUrl         String?
  coverImageUrl   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members       CommunityMember[]
  events        Event[]
  studies       StudyMaterial[]
  galleryAlbums GalleryAlbum[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([city, state])
}

model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// EVENTOS
// ═══════════════════════════════════════════════════════════════

model Event {
  id             String     @id @default(cuid())
  tenantId       String
  communityId    String?
  createdById    String
  title          String
  description    String?    @db.Text
  dateTime       DateTime
  endTime        DateTime?
  location       String?
  meetingUrl     String?
  imageUrl       String?
  eventType      EventType  @default(IN_PERSON)
  isLiveStream   Boolean    @default(false)
  maxAttendees   Int?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  community     Community?          @relation(fields: [communityId], references: [id], onDelete: SetNull)
  createdBy     User                @relation("EventCreator", fields: [createdById], references: [id])
  registrations EventRegistration[]
  liveStreams   LiveStream[]
  speakers      SpeakerEvent[]
  certificates  Certificate[]

  @@index([tenantId])
  @@index([communityId])
  @@index([dateTime])
}

model EventRegistration {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  registeredAt DateTime @default(now())
  attended    Boolean  @default(false)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// ESTUDOS
// ═══════════════════════════════════════════════════════════════

model StudyCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?  @db.Text
  parentId    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   StudyCategory?   @relation("CategoryTree", fields: [parentId], references: [id])
  children StudyCategory[]  @relation("CategoryTree")
  materials StudyMaterial[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
}

model StudyMaterial {
  id            String       @id @default(cuid())
  tenantId      String
  communityId   String?
  uploadedById  String
  title         String
  description   String?      @db.Text
  categoryId    String?
  materialType  MaterialType @default(DOCUMENT)
  fileUrl       String?
  externalUrl   String?
  thumbnailUrl  String?
  duration      Int?
  isPublic      Boolean      @default(true)
  downloadCount Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  community  Community?      @relation(fields: [communityId], references: [id], onDelete: SetNull)
  uploadedBy User            @relation("StudyUploader", fields: [uploadedById], references: [id])
  category   StudyCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([categoryId])
  @@index([communityId])
}

// ═══════════════════════════════════════════════════════════════
// LIVE STREAMS
// ═══════════════════════════════════════════════════════════════

model LiveStream {
  id           String         @id @default(cuid())
  tenantId     String
  eventId      String?
  platform     StreamPlatform @default(YOUTUBE)
  streamUrl    String
  chatUrl      String?
  embedCode    String?        @db.Text
  chatEnabled  Boolean        @default(true)
  status       StreamStatus   @default(SCHEDULED)
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  viewerCount  Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event  Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([eventId])
  @@index([scheduledAt])
}

// ═══════════════════════════════════════════════════════════════
// TZEDAKÁ
// ═══════════════════════════════════════════════════════════════

model TzedakaCampaign {
  id            String         @id @default(cuid())
  tenantId      String
  title         String
  description   String?        @db.Text
  goalAmount    Decimal?       @db.Decimal(10, 2)
  currentAmount Decimal        @default(0) @db.Decimal(10, 2)
  currency      String         @default("BRL")
  status        CampaignStatus @default(DRAFT)
  coverUrl      String?
  startDate     DateTime?
  endDate       DateTime?
  isPublic      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  donations   TzedakaDonation[]
  allocations TzedakaAllocation[]

  @@index([tenantId])
  @@index([status])
}

model TzedakaDonation {
  id            String         @id @default(cuid())
  tenantId      String
  campaignId    String?
  userId        String?
  donorName     String?
  amount        Decimal        @db.Decimal(10, 2)
  currency      String         @default("BRL")
  status        DonationStatus @default(PENDING)
  paymentMethod String?
  transactionId String?
  isAnonymous   Boolean        @default(false)
  message       String?        @db.Text
  donatedAt     DateTime       @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign TzedakaCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user     User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([campaignId])
  @@index([userId])
  @@index([donatedAt])
}

model TzedakaAllocation {
  id          String   @id @default(cuid())
  tenantId    String
  campaignId  String?
  amount      Decimal  @db.Decimal(10, 2)
  description String
  recipient   String?
  allocatedAt DateTime @default(now())

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign TzedakaCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([campaignId])
}

model TzedakaReport {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  summary     String?  @db.Text
  periodStart DateTime
  periodEnd   DateTime
  totalReceived Decimal @db.Decimal(10, 2)
  totalAllocated Decimal @db.Decimal(10, 2)
  publishedAt DateTime?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════
// BIBLIOTECA MULTIMÍDIA
// ═══════════════════════════════════════════════════════════════

model LibraryAuthor {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  bio       String?  @db.Text
  photoUrl  String?
  website   String?
  createdAt DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  LibraryItem[]

  @@index([tenantId])
}

model LibraryCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?  @db.Text
  parentId    String?
  order       Int      @default(0)

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   LibraryCategory?  @relation("LibraryCatTree", fields: [parentId], references: [id])
  children LibraryCategory[] @relation("LibraryCatTree")
  items    LibraryItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model LibraryItem {
  id           String       @id @default(cuid())
  tenantId     String
  authorId     String?
  categoryId   String?
  title        String
  description  String?      @db.Text
  materialType MaterialType
  fileUrl      String?
  externalUrl  String?
  thumbnailUrl String?
  isbn         String?
  pageCount    Int?
  duration     Int?
  language     String       @default("pt-BR")
  isPublic     Boolean      @default(true)
  downloadCount Int         @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author   LibraryAuthor?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category LibraryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags     LibraryItemTag[]

  @@index([tenantId])
  @@index([materialType])
  @@index([categoryId])
}

model LibraryTag {
  id       String @id @default(cuid())
  tenantId String
  name     String

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  LibraryItemTag[]

  @@unique([tenantId, name])
}

model LibraryItemTag {
  itemId String
  tagId  String

  item LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  LibraryTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

// ═══════════════════════════════════════════════════════════════
// FÓRUM
// ═══════════════════════════════════════════════════════════════

model ForumCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  topics ForumTopic[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model ForumTopic {
  id        String   @id @default(cuid())
  tenantId  String
  categoryId String
  authorId  String
  title     String
  isPinned  Boolean  @default(false)
  isLocked  Boolean  @default(false)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id])
  posts    ForumPost[]

  @@index([tenantId])
  @@index([categoryId])
}

model ForumPost {
  id        String   @id @default(cuid())
  tenantId  String
  topicId   String
  authorId  String
  content   String   @db.Text
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  topic     ForumTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id])
  reactions ForumReaction[]

  @@index([tenantId])
  @@index([topicId])
}

model ForumReaction {
  id     String @id @default(cuid())
  postId String
  userId String
  type   String @default("LIKE")

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id])

  @@unique([postId, userId, type])
}

// ═══════════════════════════════════════════════════════════════
// PERGUNTE AO RABINO
// ═══════════════════════════════════════════════════════════════

model RabbiProfile {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  title     String?
  bio       String?  @db.Text
  photoUrl  String?
  email     String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  answers RabbiAnswer[]

  @@index([tenantId])
}

model RabbiQuestion {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  question  String         @db.Text
  category  String?
  status    QuestionStatus @default(PENDING)
  isPublic  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id])
  answers RabbiAnswer[]

  @@index([tenantId, status])
  @@index([userId])
}

model RabbiAnswer {
  id          String   @id @default(cuid())
  questionId  String
  rabbiId     String
  answer      String   @db.Text
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  question RabbiQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  rabbi    RabbiProfile  @relation(fields: [rabbiId], references: [id])

  @@index([questionId])
  @@index([rabbiId])
}

// ═══════════════════════════════════════════════════════════════
// ASSISTENTE IA
// ═══════════════════════════════════════════════════════════════

model AIConversation {
  id        String       @id @default(cuid())
  tenantId  String
  userId    String
  title     String?
  model     String       @default("default")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([tenantId, userId])
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AIConfig {
  id              String   @id @default(cuid())
  tenantId        String
  apiKey          String?
  model           String   @default("gpt-4o-mini")
  systemPrompt    String?  @db.Text
  maxTokens       Int      @default(1000)
  temperature     Float    @default(0.7)
  isEnabled       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@index([tenantId])
}

model AIUsageLog {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String
  conversationId  String?
  model           String
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  totalTokens     Int      @default(0)
  latencyMs       Int?
  success         Boolean  @default(true)
  errorMessage    String?
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// GALERIA
// ═══════════════════════════════════════════════════════════════

model GalleryAlbum {
  id          String   @id @default(cuid())
  tenantId    String
  communityId String?
  title       String
  description String?  @db.Text
  coverUrl    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  community Community?     @relation(fields: [communityId], references: [id], onDelete: SetNull)
  media     GalleryMedia[]

  @@index([tenantId])
}

model GalleryMedia {
  id           String    @id @default(cuid())
  albumId      String
  tenantId     String
  type         MediaType @default(IMAGE)
  url          String
  thumbnailUrl String?
  title        String?
  caption      String?
  width        Int?
  height       Int?
  duration     Int?
  uploadedById String
  createdAt    DateTime  @default(now())

  album      GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User         @relation(fields: [uploadedById], references: [id])

  @@index([albumId])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════
// NOTÍCIAS
// ═══════════════════════════════════════════════════════════════

model NewsCategory {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  slug     String
  color    String?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  articles NewsArticle[]

  @@unique([tenantId, slug])
}

model NewsArticle {
  id          String        @id @default(cuid())
  tenantId    String
  authorId    String
  categoryId  String?
  title       String
  slug        String
  excerpt     String?       @db.Text
  body        String        @db.Text
  coverUrl    String?
  status      PublishStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author   User            @relation("NewsAuthor", fields: [authorId], references: [id])
  category NewsCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags     NewsArticleTag[]
  comments NewsComment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, publishedAt])
}

model NewsTag {
  id       String  @id @default(cuid())
  tenantId String
  name     String

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  articles NewsArticleTag[]

  @@unique([tenantId, name])
}

model NewsArticleTag {
  articleId String
  tagId     String

  article NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     NewsTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model NewsComment {
  id         String   @id @default(cuid())
  articleId  String
  userId     String
  content    String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  article NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@index([articleId])
}

// ═══════════════════════════════════════════════════════════════
// CERTIFICADOS
// ═══════════════════════════════════════════════════════════════

model CertificateTemplate {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  title    String
  subtitle String?
  borderStyle String @default("classic")
  fontFamily  String @default("serif")
  primaryColor String @default("#1a56db")
  accentColor  String @default("#f59e0b")
  isActive Boolean @default(true)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  certificates Certificate[]

  @@index([tenantId])
}

model Certificate {
  id                String           @id @default(cuid())
  tenantId          String
  templateId        String
  userId            String
  eventId           String?
  certificateNumber String           @unique
  recipientName     String
  completionDate    DateTime?
  expiryDate        DateTime?
  status            CertificateStatus @default(ACTIVE)
  pdfUrl            String?
  issuedAt          DateTime         @default(now())

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template CertificateTemplate @relation(fields: [templateId], references: [id])
  user     User                @relation(fields: [userId], references: [id])
  event    Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId])
  @@index([certificateNumber])
}

// ═══════════════════════════════════════════════════════════════
// INSTITUIÇÕES PARCEIRAS
// ═══════════════════════════════════════════════════════════════

model PartnerInstitution {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?  @db.Text
  logoUrl         String?
  website         String?
  email           String?
  phone           String?
  address         String?
  partnershipType String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  representatives InstitutionRepresentative[]

  @@index([tenantId])
}

model InstitutionRepresentative {
  id            String @id @default(cuid())
  institutionId String
  name          String
  role          String?
  email         String?
  phone         String?

  institution PartnerInstitution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
}

// ═══════════════════════════════════════════════════════════════
// PALESTRANTES
// ═══════════════════════════════════════════════════════════════

model Speaker {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  @unique
  name      String
  title     String?
  bio       String?  @db.Text
  photoUrl  String?
  email     String?
  phone     String?
  website   String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?              @relation(fields: [userId], references: [id])
  expertise SpeakerExpertise[]
  events    SpeakerEvent[]

  @@unique([tenantId, userId])
  @@index([tenantId])
}

model SpeakerExpertise {
  id        String @id @default(cuid())
  speakerId String
  topic     String

  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@index([speakerId])
}

model SpeakerEvent {
  id        String @id @default(cuid())
  speakerId String
  eventId   String

  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([speakerId, eventId])
}

// ═══════════════════════════════════════════════════════════════
// BANNERS
// ═══════════════════════════════════════════════════════════════

model Banner {
  id          String         @id @default(cuid())
  tenantId    String
  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  position    BannerPosition @default(HOME_HERO)
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, position, isActive])
}

// ═══════════════════════════════════════════════════════════════
// NOTIFICAÇÕES
// ═══════════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  message   String           @db.Text
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, isRead])
}

// ═══════════════════════════════════════════════════════════════
// CMS
// ═══════════════════════════════════════════════════════════════

model Page {
  id              String   @id @default(cuid())
  tenantId        String
  slug            String
  title           String
  body            String   @db.Text
  isPublished     Boolean  @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════
// INTEGRAÇÕES
// ═══════════════════════════════════════════════════════════════

model IntegrationConfig {
  id        String   @id @default(cuid())
  tenantId  String
  provider  String
  apiKey    String?
  apiSecret String?
  webhookUrl String?
  extraConfig String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
}

// ═══════════════════════════════════════════════════════════════
// AUDITORIA
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String?
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  oldValues  String?     @db.Text
  newValues  String?     @db.Text
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// PEDIDOS DE ORAÇÃO
// ═══════════════════════════════════════════════════════════════

model PrayerRequest {
  id          String            @id @default(cuid())
  tenantId    String
  userId      String
  title       String
  description String            @db.Text
  category    PrayerCategory    @default(GENERAL)
  isAnonymous Boolean           @default(false)
  isPublic    Boolean           @default(true)
  status      PrayerStatus      @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id])
  responses PrayerResponse[]

  @@index([tenantId, status])
  @@index([userId])
}

model PrayerResponse {
  id         String   @id @default(cuid())
  requestId  String
  userId     String
  message    String   @db.Text
  createdAt  DateTime @default(now())

  request PrayerRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id])

  @@index([requestId])
}

// ═══════════════════════════════════════════════════════════════
// VOLUNTARIADO
// ═══════════════════════════════════════════════════════════════

model VolunteerOpportunity {
  id          String   @id @default(cuid())
  tenantId    String
  communityId String?
  title       String
  description String?  @db.Text
  requirements String? @db.Text
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  maxVolunteers Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  signups   VolunteerSignup[]

  @@index([tenantId])
}

model VolunteerSignup {
  id            String   @id @default(cuid())
  opportunityId String
  userId        String
  status        VolunteerStatus @default(PENDING)
  hoursLogged   Decimal? @db.Decimal(5, 2)
  notes         String?  @db.Text
  signedUpAt    DateTime @default(now())

  opportunity VolunteerOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id])

  @@unique([opportunityId, userId])
  @@index([opportunityId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// MENTORIA
// ═══════════════════════════════════════════════════════════════

model MentorProfile {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  expertise  String?
  bio        String?  @db.Text
  isAvailable Boolean @default(true)
  maxMentees Int      @default(3)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId])
}

model Mentorship {
  id          String         @id @default(cuid())
  tenantId    String
  mentorId    String
  menteeId    String
  status      MentorshipStatus @default(ACTIVE)
  startDate   DateTime       @default(now())
  endDate     DateTime?
  notes       String?        @db.Text
  createdAt   DateTime       @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mentor User        @relation("Mentor", fields: [mentorId], references: [id])
  mentee User        @relation("Mentee", fields: [menteeId], references: [id])

  @@unique([tenantId, mentorId, menteeId])
  @@index([tenantId])
  @@index([mentorId])
  @@index([menteeId])
}

// ═══════════════════════════════════════════════════════════════
// FAVORITOS
// ═══════════════════════════════════════════════════════════════

model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  entityType String   // "STUDY", "EVENT", "LIBRARY", "NEWS", "COMMUNITY"
  entityId   String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([userId])
  @@index([entityType, entityId])
}

// ═══════════════════════════════════════════════════════════════
// HISTÓRICO DE PESQUISAS
// ═══════════════════════════════════════════════════════════════

model SearchHistory {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  query     String
  module    String?  // "STUDIES", "LIBRARY", "EVENTS", "NEWS", "AI"
  resultsCount Int  @default(0)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([query])
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum TenantRole {
  MEMBER
  LEADER
  ADMIN
}

enum CommunityRole {
  MEMBER
  LEADER
  ADMIN
}

enum EventType {
  IN_PERSON
  ONLINE
  HYBRID
}

enum MaterialType {
  DOCUMENT
  VIDEO
  AUDIO
  LINK
}

enum StreamPlatform {
  YOUTUBE
  VIMEO
  ZOOM
  GOOGLE_MEET
  MS_TEAMS
  OTHER
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum PublishStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum QuestionStatus {
  PENDING
  UNDER_REVIEW
  ANSWERED
  PUBLISHED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum NotificationType {
  GENERAL
  EVENT
  STUDY
  COMMUNITY
  TZEDAKA
  FORUM
  RABBI
  NEWS
  PRAYER
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CertificateStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum BannerPosition {
  HOME_HERO
  HOME_SIDEBAR
  HOME_MID
  COMMUNITY_TOP
  EVENT_TOP
  GLOBAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VIEW
  EXPORT
}

enum PrayerCategory {
  GENERAL
  HEALTH
  FAMILY
  SHALOM
  PARNASSA
  STUDY
  COMMUNITY
}

enum PrayerStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum VolunteerStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum MentorshipStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}
